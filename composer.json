{
  "name": "inspirelabs/rehabilito-integration",
  "authors": [
    {
      "name": "iLabs",
      "email": "biuro@inspirelabs.pl"
    }
  ],
  "autoload": {
    "psr-4": {
      "Ilabs\\Inpost_Pay\\": "src",
      "Isolated\\Inpost_Pay\\Ilabs\\Ilabs_Plugin\\": "vendor/isolated-ilabs-plugin/ilabs-plugin/src"
    }
  },
  "scripts": {
    "cs": "vendor/bin/phpcs --standard=phpcs.xml src/",
    "cbf": "vendor/bin/phpcbf src/",
    "stan": "vendor/bin/phpstan --memory-limit=2G",
    "stancc": "rm -rf phpstan/cache"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.10",
    "squizlabs/php_codesniffer": "^3.7",
    "wp-coding-standards/wpcs": "^3.1",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "php-stubs/wordpress-stubs": "^6.5",
    "php-stubs/woocommerce-stubs": "^8.0"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "repositories": [
    {
      "type": "package",
      "package": {
        "name": "isolated-ilabs-plugin/ilabs-plugin",
        "version": "1.3.1",
        "dist": {
          "type": "zip",
          "url": "ilabs/setup/isolated_dependencies/isolated-ilabs-plugin-1.3.1.zip"
        }
      }
    },
    {
      "type": "package",
      "package": {
        "name": "isolated-pimple-pimple/isolated-pimple",
        "version": "3.4.0",
        "dist": {
          "type": "zip",
          "url": "ilabs/setup/isolated_dependencies/isolated-pimple-3.4.0.zip"
        }
      }
    },
    {
      "type": "package",
      "package": {
        "name": "isolated-maennchen-zipstream/isolated-zipstream",
        "version": "2.1.0",
        "dist": {
          "type": "zip",
          "url": "ilabs/setup/isolated_dependencies/isolated-zipstream-2.1.0.zip"
        }
      }
    },
    {
      "type": "package",
      "package": {
        "name": "isolated-guzzlehttp-guzzle/isolated-guzzle",
        "version": "7.5.1",
        "dist": {
          "type": "zip",
          "url": "ilabs/setup/isolated_dependencies/isolated-guzzle-7.5.1.zip"
        }
      }
    }
  ],
  "require": {
    "isolated-ilabs-plugin/ilabs-plugin": "1.3.1",
    "isolated-pimple-pimple/isolated-pimple": "3.4.0",
    "isolated-maennchen-zipstream/isolated-zipstream": "2.1.0",
    "isolated-guzzlehttp-guzzle/isolated-guzzle": "7.5.1"
  }
}
